# =============================================================================
# Safe Ride Network — Environment Variables
# =============================================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local   (Mac/Linux)
#   copy .env.example .env.local (Windows)
#
# For production, set these in Vercel → Project Settings → Environment Variables.
# Never commit `.env.local` or real secrets to git.
# =============================================================================


# -----------------------------------------------------------------------------
# App / Site
# -----------------------------------------------------------------------------

# Canonical production URL (no trailing slash). Used for Stripe redirects,
# Connect onboarding return URLs, and checkout success/cancel links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional display values (currently hardcoded in some pages; safe to set for future use)
NEXT_PUBLIC_PHONE_NUMBER=(316) 555-0192
NEXT_PUBLIC_EMAIL=dispatch@saferidenetwork.com
NEXT_PUBLIC_LOCATION=Wichita, Kansas


# -----------------------------------------------------------------------------
# Supabase (Database, Auth, Storage)
# -----------------------------------------------------------------------------

# Project URL — Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Required for Stripe webhooks, Connect transfers, and admin server operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# -----------------------------------------------------------------------------
# Stripe (Payments + Connect)
# -----------------------------------------------------------------------------

# Secret key — SERVER ONLY. Dashboard → Developers → API keys
# Use sk_test_... for test mode, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret — SERVER ONLY.
# Created after adding the webhook endpoint in Stripe Dashboard.
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Publishable key — optional today; used if client-side Stripe.js is added later.
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key


# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------

# Required for trip maps, location picker, and distance/price calculation.
# Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Directions API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional server-side fallback (used by /api/maps/distance if set)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key


# -----------------------------------------------------------------------------
# Email (Resend) — rider notification emails
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Safe Ride Network <notifications@saferidenetwork.com>


# -----------------------------------------------------------------------------
# SMS (Twilio) — rider notification texts (optional; logs placeholder if unset)
# -----------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567


# -----------------------------------------------------------------------------
# Internal secrets (cron, service-to-service)
# -----------------------------------------------------------------------------

CRON_SECRET=your-cron-secret
NOTIFICATION_INTERNAL_SECRET=your-internal-notification-secret
